13:["$","$L9",null,{"code":"import { useResetTheme } from 'ospinajuanp-reset-css/react';\n\nfunction ThemeSwitcher() {\n  const { theme, setTheme, themes } = useResetTheme('dark');\n\n  return (\n    <div>\n      <p>Current theme: {theme}</p>\n      <select value={theme} onChange={(e) => setTheme(e.target.value)}>\n        {themes.map(t => <option key={t} value={t}>{t}</option>)}\n      </select>\n    </div>\n  );\n}"}]
14:["$","h3",null,{"children":"Using ThemeProvider"}]
15:["$","$L9",null,{"code":"import { ThemeProvider, useTheme } from 'ospinajuanp-reset-css/react';\n\nfunction ThemeSwitcher() {\n  const { theme, setTheme, themes } = useTheme();\n  return (\n    <select value={theme} onChange={(e) => setTheme(e.target.value)}>\n      {themes.map(t => <option key={t} value={t}>{t}</option>)}\n    </select>\n  );\n}\n\nexport default function App() {\n  return (\n    <ThemeProvider defaultTheme=\"dark\">\n      <ThemeSwitcher />\n    </ThemeProvider>\n  );\n}"}]
