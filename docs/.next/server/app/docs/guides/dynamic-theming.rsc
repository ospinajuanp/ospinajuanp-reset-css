a:["$","h2",null,{"children":"User Preference Storage"}]
b:["$","p",null,{"children":"Persist user theme choice in localStorage:"}]
c:["$","$L9",null,{"code":"import { setTheme, getTheme } from 'ospinajuanp-reset-css/api';\n\n// On app init\nconst savedTheme = localStorage.getItem('theme') || 'system';\nsetTheme(savedTheme);\n\n// On theme change\nfunction handleThemeChange(newTheme) {\n  setTheme(newTheme);\n  localStorage.setItem('theme', newTheme);\n}"}]
d:["$","h2",null,{"children":"React Implementation"}]
e:["$","p",null,{"children":"Combine with React hooks for a complete solution:"}]
f:["$","$L9",null,{"code":"import { useEffect, useState } from 'react';\nimport { useTheme } from 'ospinajuanp-reset-css/react';\n\nfunction ThemeManager() {\n  const { theme, setTheme } = useTheme();\n\n  useEffect(() => {\n    // Restore saved preference on mount\n    const saved = localStorage.getItem('theme');\n    if (saved) setTheme(saved);\n  }, []);\n\n  const handleChange = (newTheme) => {\n    setTheme(newTheme);\n    localStorage.setItem('theme', newTheme);\n  };\n\n  return (\n    <select value={theme} onChange={(e) => handleChange(e.target.value)}>\n      <option value=\"simple\">Simple</option>\n      <option value=\"dark\">Dark</option>\n      <option value=\"pastel\">Pastel</option>\n    </select>\n  );\n}"}]
